# Agent-kit dev: routes wp/audit/test/lint to source so the compiled binary stays canonical
# for consumers while you iterate here. The F1 exception keeps latency-sensitive wp-* hook
# bins on the compiled binary — see bin/_run.js for details.
# First use: run `direnv allow` once. No direnv? Use `vp run wp:source -- …` for ad-hoc source runs.
export WP_FORCE_SOURCE=1
