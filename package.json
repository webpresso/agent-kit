  "scripts": {
    "build": "tshy && pnpm run chmod-bins && pnpm run link-self-bins",
    "postbuild": "pnpm run generate-skills",
    "chmod-bins": "bun scripts/chmod-bins.ts",
    "link-self-bins": "bun scripts/link-self-bins.ts",
    "dev:link": "bun scripts/link-edge-local.ts",
    "generate-skills": "bun src/build/generate-skills-dir.ts",
    "sync-marketplace-version": "bun scripts/sync-marketplace-version.ts",
    "version": "changeset version && pnpm run sync-marketplace-version",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:mutation": "bun stryker run stryker.config.ts",
    "eval": "bun src/runners/evals/index.ts",
    "lint": "bun ./src/cli/cli.ts lint",
    "lint:fix": "bun ./src/cli/cli.ts lint --fix",
    "format": "bun ./src/cli/cli.ts format",
    "format:check": "bun ./src/cli/cli.ts format --check",
    "lint:pkg": "publint && attw --pack . && (command -v claude >/dev/null 2>&1 && claude plugin validate . || true)",
    "blueprints:check": "bun ./src/cli/cli.ts audit blueprint-lifecycle",
    "docs:check": "bun ./src/cli/cli.ts audit docs-frontmatter",
    "catalog:check": "bun ./src/cli/cli.ts audit catalog-drift",
    "imports:check": "bun ./src/cli/cli.ts audit no-relative-parent-imports",
    "audits:check": "bun ./src/cli/cli.ts audit guardrails && pnpm hooks:doctor:ci",
    "hooks:doctor": "bun ./src/cli/cli.ts hooks doctor",
    "hooks:doctor:ci": "bun ./src/cli/cli.ts hooks doctor --skip-mcp",
    "qa": "bun run build && bun run typecheck && bun run lint && bun run format:check && bun run test && bun run lint:pkg && bun run audits:check",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "postinstall": "bun scripts/migration-notice.ts",
    "prepublishOnly": "pnpm run build"
  },
