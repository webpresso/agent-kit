{
  "name": "@webpresso/agent-kit",
  "version": "0.3.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webpresso/agent-kit.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "description": "Toolkit for agent-driven development: Blueprint runtime, agent-surface symlinker, skills catalog, and the `ak` CLI that ties them together.",
  "keywords": [
    "agent",
    "agent-kit",
    "blueprint",
    "claude-code",
    "gemini-cli",
    "implementation-plan",
    "skills"
  ],
  "license": "MIT",
  "bin": {
    "ak-pretool-guard": "./src/hooks/pretool-guard/index.ts",
    "ak-post-tool": "./src/hooks/post-tool/lint-after-edit.ts",
    "ak-stop-qa": "./src/hooks/stop/qa-changed-files.ts",
    "ak-guard-switch": "./src/hooks/guard-switch/index.ts",
    "ak-test-quality-check": "./src/hooks/test-quality-check.ts",
    "ak-sessionstart-routing": "./src/hooks/sessionstart/index.ts"
  },
  "files": [
    "dist",
    "src",
    "catalog",
    "just",
    "docs",
    "skills",
    "commands",
    ".claude-plugin",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/esm/index.js",
  "imports": {
    "#e2e": "./src/e2e/index.ts",
    "#e2e/*": "./src/e2e/*.ts",
    "#test": "./src/test/index.ts",
    "#symlinker": "./src/symlinker/index.ts",
    "#cli/*": "./src/cli/*.ts",
    "#dev/*": "./src/dev/*.ts",
    "#audit/*": "./src/audit/*.ts",
    "#docs-linter/*": "./src/docs-linter/*.ts",
    "#hooks/*": "./src/hooks/*.ts",
    "#mcp/*": "./src/mcp/*.ts",
    "#*": "./src/blueprint/*.ts"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./blueprint": {
      "import": {
        "types": "./dist/esm/blueprint/index.d.ts",
        "default": "./dist/esm/blueprint/index.js"
      }
    },
    "./blueprint/dag": {
      "import": {
        "types": "./dist/esm/blueprint/dag/index.d.ts",
        "default": "./dist/esm/blueprint/dag/index.js"
      }
    },
    "./blueprint/dag/local": {
      "import": {
        "types": "./dist/esm/blueprint/dag/local/index.d.ts",
        "default": "./dist/esm/blueprint/dag/local/index.js"
      }
    },
    "./blueprint/local": {
      "import": {
        "types": "./dist/esm/blueprint/local.d.ts",
        "default": "./dist/esm/blueprint/local.js"
      }
    },
    "./blueprint/tech-debt": {
      "import": {
        "types": "./dist/esm/blueprint/tech-debt/index.d.ts",
        "default": "./dist/esm/blueprint/tech-debt/index.js"
      }
    },
    "./blueprint/test-utils": {
      "import": {
        "types": "./dist/esm/blueprint/test-utils/blueprint-mocks.d.ts",
        "default": "./dist/esm/blueprint/test-utils/blueprint-mocks.js"
      }
    },
    "./blueprint/tracked-document": {
      "import": {
        "types": "./dist/esm/blueprint/tracked-document/index.d.ts",
        "default": "./dist/esm/blueprint/tracked-document/index.js"
      }
    },
    "./blueprint/validation": {
      "import": {
        "types": "./dist/esm/blueprint/core/validation/index.d.ts",
        "default": "./dist/esm/blueprint/core/validation/index.js"
      }
    },
    "./catalog/*": "./catalog/*",
    "./dev": {
      "import": {
        "types": "./dist/esm/dev/index.d.ts",
        "default": "./dist/esm/dev/index.js"
      }
    },
    "./docs-linter": {
      "import": {
        "types": "./dist/esm/docs-linter/index.d.ts",
        "default": "./dist/esm/docs-linter/index.js"
      }
    },
    "./e2e": {
      "import": {
        "types": "./dist/esm/e2e/index.d.ts",
        "default": "./dist/esm/e2e/index.js"
      }
    },
    "./lint": {
      "import": {
        "types": "./dist/esm/lint/index.d.ts",
        "default": "./dist/esm/lint/index.js"
      }
    },
    "./local": {
      "import": {
        "types": "./dist/esm/local.d.ts",
        "default": "./dist/esm/local.js"
      }
    },
    "./symlinker": {
      "import": {
        "types": "./dist/esm/symlinker/index.d.ts",
        "default": "./dist/esm/symlinker/index.js"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/esm/test/index.d.ts",
        "default": "./dist/esm/test/index.js"
      }
    },
    "./typecheck": {
      "import": {
        "types": "./dist/esm/typecheck/index.d.ts",
        "default": "./dist/esm/typecheck/index.js"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/esm/vite/index.d.ts",
        "default": "./dist/esm/vite/index.js"
      }
    },
    "./vite/local": {
      "import": {
        "types": "./dist/esm/vite/local.d.ts",
        "default": "./dist/esm/vite/local.js"
      }
    }
  },
  "scripts": {
    "build": "tshy && pnpm run chmod-bins && pnpm run link-self-bins",
    "postbuild": "pnpm run generate-skills",
    "chmod-bins": "tsx scripts/chmod-bins.ts",
    "link-self-bins": "tsx scripts/link-self-bins.ts",
    "generate-skills": "tsx src/build/generate-skills-dir.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:mutation": "bun stryker run --configFile stryker.config.ts",
    "lint:pkg": "publint && attw --pack . && (command -v claude >/dev/null 2>&1 && claude plugin validate . || true)",
    "blueprints:check": "bun ./src/cli/cli.ts audit blueprint-lifecycle",
    "docs:check": "bun ./src/cli/cli.ts audit docs-frontmatter",
    "catalog:check": "bun ./src/cli/cli.ts audit catalog-drift",
    "imports:check": "bun ./src/cli/cli.ts audit no-relative-parent-imports",
    "audits:check": "bun ./src/cli/cli.ts audit guardrails && pnpm hooks:doctor:ci",
    "hooks:doctor": "bun ./src/cli/cli.ts hooks doctor",
    "hooks:doctor:ci": "bun ./src/cli/cli.ts hooks doctor --skip-mcp",
    "qa": "bun run build && bun run typecheck && bun run test && bun run lint:pkg && bun run audits:check",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@manypkg/find-root": "3.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cac": "^6.7.14",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/bun": "^1.1.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@webpresso/stryker-config": "^0.1.0",
    "husky": "^9.0.0",
    "publint": "^0.3.18",
    "tshy": "^4.1.1",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  },
  "tshy": {
    "dialects": [
      "esm"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "src/**/*.integration.test.ts",
      "src/**/__fixtures__/**"
    ],
    "exports": {
      ".": "./src/index.ts",
      "./blueprint": "./src/blueprint/index.ts",
      "./blueprint/dag": "./src/blueprint/dag/index.ts",
      "./blueprint/dag/local": "./src/blueprint/dag/local/index.ts",
      "./blueprint/local": "./src/blueprint/local.ts",
      "./blueprint/tech-debt": "./src/blueprint/tech-debt/index.ts",
      "./blueprint/test-utils": "./src/blueprint/test-utils/blueprint-mocks.ts",
      "./blueprint/tracked-document": "./src/blueprint/tracked-document/index.ts",
      "./blueprint/validation": "./src/blueprint/core/validation/index.ts",
      "./catalog/*": "./catalog/*",
      "./dev": "./src/dev/index.ts",
      "./docs-linter": "./src/docs-linter/index.ts",
      "./e2e": "./src/e2e/index.ts",
      "./lint": "./src/lint/index.ts",
      "./local": "./src/local.ts",
      "./symlinker": "./src/symlinker/index.ts",
      "./test": "./src/test/index.ts",
      "./typecheck": "./src/typecheck/index.ts",
      "./vite": "./src/vite/index.ts",
      "./vite/local": "./src/vite/local.ts"
    },
    "selfLink": false
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
