# Test fixture: a fake `omx` binary that responds the way real omx would
# for `--version` and `setup --yes`. Used to live-verify ak setup --with
# omx without invoking the real omx CLI.
case "$1" in
  --version)
    echo "omx-fixture 1.0.0"
    exit 0
    ;;
  setup)
    echo "omx-fixture: setup --yes ran (no-op)"
    exit 0
    ;;
  *)
    echo "omx-fixture: unknown subcommand: $1" >&2
    exit 64
    ;;
esac
