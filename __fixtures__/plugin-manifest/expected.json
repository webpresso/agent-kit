{
  "name": "webpresso-agent-kit",
  "version": "0.1.0",
  "description": "Webpresso agent-kit: blueprints, skills, lore commit protocol, tech-debt lifecycle",
  "skills": "./skills",
  "commands": "./commands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/dist/esm/hooks/pretool-guard/index.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/dist/esm/hooks/post-tool/lint-after-edit.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/dist/esm/hooks/stop/qa-changed-files.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/dist/esm/hooks/sessionstart/index.js"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "agent-kit": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/esm/mcp/cli.js"]
    }
  }
}
