name: CI (webpresso baseline)

on:
  push:
    branches: [main, master]
  pull_request:

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '24'
      - uses: pnpm/action-setup@v4
        with:
          version: '10.33.0'
      - run: pnpm install --frozen-lockfile
      - run: pnpm -r run check-types 2>/dev/null || pnpm -r run typecheck
      - run: pnpm -r run lint

  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '24'
      - uses: pnpm/action-setup@v4
        with:
          version: '10.33.0'
      - run: pnpm install --frozen-lockfile
      - run: pnpm -r run test

  ak-audits:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '24'
      - uses: pnpm/action-setup@v4
        with:
          version: '10.33.0'
      - run: pnpm install --frozen-lockfile
      - run: |
          which claude && claude install-plugin @webpresso/agent-kit || echo "Claude Code not installed, skipping plugin install"
      - run: npx ak audit guardrails
