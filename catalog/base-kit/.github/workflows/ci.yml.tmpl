name: CI

on:
  push:
    branches: [main, master]
  pull_request:

env:
  # Opt the workflow's JavaScript actions into Node.js 24 ahead of the
  # 2026-06-02 GitHub default switch (replaces the deprecation warning
  # surfaced by actions/checkout@v4, actions/setup-node@v4, and
  # pnpm/action-setup@v4 internally running on Node 20).
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: 'true'

jobs:
  quality:
    name: quality
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: voidzero-dev/setup-vp@v1
        with:
          node-version: '24.16.0'
          cache: true
          run-install: false
      - run: vp install -g @webpresso/agent-kit@2.3.2
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: vp install --frozen-lockfile
      - run: vp run verify:secrets
      - run: vp run audit:secret-provider-quarantine
      - name: Run wp audit guardrails
        run: wp audit guardrails
      - run: vp run typecheck
      - run: vp run lint
      - run: vp run test

  e2e:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: voidzero-dev/setup-vp@v1
        with:
          node-version: '24.16.0'
          cache: true
          run-install: false
      - run: vp install -g @webpresso/agent-kit@2.3.2
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: vp install --frozen-lockfile
      - name: Run e2e when Playwright bootstrap is present
        run: |
          if [ ! -f playwright.config.ts ]; then
            echo "Skipping e2e: playwright.config.ts not present."
            exit 0
          fi

          vp run e2e

  architecture-drift:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: voidzero-dev/setup-vp@v1
        with:
          node-version: '24.16.0'
          cache: true
          run-install: false
      - run: vp install -g @webpresso/agent-kit@2.3.2
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: vp install --frozen-lockfile
      - name: Check architecture drift contract
        run: wp audit architecture-drift --root .

  deploy-verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: voidzero-dev/setup-vp@v1
        with:
          node-version: '24.16.0'
          cache: true
          run-install: false
      - run: vp install -g @webpresso/agent-kit@2.3.2
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: vp install --frozen-lockfile
      - name: Verify deploy-contract gate when production release metadata is present
        run: |
          set -euo pipefail

          METADATA_PATH='infra/release-metadata.production.json'

          if [ ! -f "$METADATA_PATH" ]; then
            echo "No production release metadata present at $METADATA_PATH; skipping deploy-contract gate."
            exit 0
          fi

          if ! node -e "const pkg=require('./package.json'); process.exit(pkg.scripts && pkg.scripts['verify:deploy-contract'] ? 0 : 1)"; then
            echo "::error::Detected $METADATA_PATH but no verify:deploy-contract script."
            echo "::error::Repos adopting the shared deploy contract must keep agent-kit provider-neutral and supply a repo-owned deploy verifier."
            echo "::error::That verifier owns provider-specific env-name derivation, Preview-URL prohibitions for DO previews, and must fail closed for migration-bearing Durable Object releases."
            exit 1
          fi

          vp run verify:deploy-contract


  wp-check:
    name: wp-check
    if: ${{ always() }}
    needs:
      - quality
      - e2e
      - architecture-drift
      - deploy-verify
    runs-on: ubuntu-latest
    steps:
      - name: Enforce aggregate branch-protection gate
        env:
          QUALITY_RESULT: ${{ needs.quality.result }}
          E2E_RESULT: ${{ needs.e2e.result }}
          ARCHITECTURE_DRIFT_RESULT: ${{ needs.architecture-drift.result }}
          DEPLOY_VERIFY_RESULT: ${{ needs.deploy-verify.result }}
        run: |
          set -euo pipefail

          for result in \
            "$QUALITY_RESULT" \
            "$E2E_RESULT" \
            "$ARCHITECTURE_DRIFT_RESULT" \
            "$DEPLOY_VERIFY_RESULT"; do
            if [ "$result" != 'success' ]; then
              echo "::error::A required CI job finished with result: $result"
              exit 1
            fi
          done
