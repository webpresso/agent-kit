name: Set up Webpresso tooling
description: >
  Install shared Webpresso CLIs needed by the base-kit workflow surface.
  Resolves repo-owned Vite+ version pins without relying on a preinstalled global `vp`.
runs:
  using: composite
  steps:
    - name: Install shared Webpresso CLIs
      shell: bash
      run: |
        set -euo pipefail
        eval "$(node ./scripts/resolve-webpresso-cli-versions.js)"

        if [[ -n "${VITE_PLUS_VERSION}" ]]; then
          npm install -g "vite-plus@${VITE_PLUS_VERSION}" "@webpresso/agent-kit@latest"
        else
          npm install -g "@webpresso/agent-kit@latest"
        fi
