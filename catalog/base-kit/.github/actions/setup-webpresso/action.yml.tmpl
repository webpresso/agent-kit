name: Set up Webpresso tooling
description: >
  Install shared Webpresso CLIs needed by the base-kit workflow surface.
  Resolves repo-owned Vite+ version pins without relying on a preinstalled global `vp`.
runs:
  using: composite
  steps:
    - name: Install shared Webpresso CLIs
      shell: bash
      run: |
        set -euo pipefail
        eval "$(node ./scripts/resolve-webpresso-cli-versions.cjs)"

        if ! command -v vp >/dev/null 2>&1; then
          curl -fsSL https://vite.plus | bash
          export PATH="$HOME/.vite-plus/bin:$PATH"
        fi
        if [[ -n "${VITE_PLUS_VERSION}" ]]; then
          vp install -g "vite-plus@${VITE_PLUS_VERSION}"
        fi
        vp install -g "@webpresso/agent-kit@latest"
