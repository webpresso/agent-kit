#!/usr/bin/env sh
set -eu
ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
BASE="$(git -C "$ROOT" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')"
if [ -z "${BASE}" ]; then
  if git -C "$ROOT" rev-parse --verify origin/main >/dev/null 2>&1; then
    BASE="main"
  elif git -C "$ROOT" rev-parse --verify origin/master >/dev/null 2>&1; then
    BASE="master"
  else
    BASE="main"
  fi
fi
git -C "$ROOT" fetch origin "${BASE}" --depth=50 2>/dev/null || true
COMMITS=$(git -C "$ROOT" rev-list --no-merges "origin/${BASE}..HEAD" 2>/dev/null || git -C "$ROOT" rev-list --no-merges "${BASE}..HEAD" 2>/dev/null || true)
if [ -z "${COMMITS}" ]; then
  exit 0
fi
FAIL=0
for SHA in ${COMMITS}; do
  git -C "$ROOT" log -1 --format="%B" "${SHA}" > /tmp/commit-msg.txt
  "$ROOT/bin/wp" audit commit-message --require-lore --message-file /tmp/commit-msg.txt || FAIL=1
done
exit "${FAIL}"
