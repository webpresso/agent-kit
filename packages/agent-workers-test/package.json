{
  "name": "@webpresso/agent-workers-test",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webpresso/workers-test-kit.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "description": "Production-ready Cloudflare Workers test mocks — BaseWorkerEnv, ExecutionContext, Hyperdrive, Durable Objects, Containers",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    }
  },
  "scripts": {
    "build": "tshy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:mutation": "stryker run",
    "lint:pkg": "attw --pack .",
    "qa": "pnpm typecheck && pnpm test && pnpm lint:pkg",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0",
    "vitest": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@cloudflare/workers-types": "^4.20250525.0",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/typescript-checker": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "@webpresso/agent-stryker": "workspace:*",
    "@webpresso/agent-tsconfig": "workspace:*",
    "tshy": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "tshy": {
    "dialects": [
      "esm"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "exports": {
      ".": "./src/index.ts"
    },
    "project": "./tsconfig.build.json",
    "selfLink": false
  },
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/esm/index.js"
}
