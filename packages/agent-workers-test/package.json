{
  "name": "@webpresso/workers-test-kit",
  "version": "0.1.0",
  "description": "Production-ready Cloudflare Workers test mocks — BaseWorkerEnv, ExecutionContext, Hyperdrive, Durable Objects, Containers",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    }
  },
  "scripts": {
    "build": "tshy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:pkg": "attw --pack .",
    "qa": "pnpm typecheck && pnpm test && pnpm lint:pkg",
    "prepublishOnly": "pnpm build && pnpm lint:pkg"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0",
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@cloudflare/workers-types": "^4.20250525.0",
    "@webpresso/typescript-config": "github:webpresso/tooling#main&path:/packages/typescript-config",
    "tshy": "^4.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "tshy": {
    "dialects": [
      "esm"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "exports": {
      ".": "./src/index.ts"
    },
    "project": "./tsconfig.build.json",
    "selfLink": false
  },
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/esm/index.js"
}
