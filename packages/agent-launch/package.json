{
  "name": "@webpresso/agent-launch",
  "version": "0.3.0",
  "deprecated": "Deprecated: migrate to the consolidated webpresso package subpath exports. See https://github.com/webpresso/agent-kit/blob/main/MIGRATION.md",
  "private": false,
  "description": "Contract-safe launch engine primitives extracted from the Webpresso monorepo.",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@webpresso/agent-tsconfig": "workspace:*",
    "@webpresso/agent-vitest": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webpresso/tooling.git",
    "directory": "packages/launch-engine"
  }
}
