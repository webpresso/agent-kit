{
  "name": "@webpresso/stryker-config",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./stryker.base.ts"
