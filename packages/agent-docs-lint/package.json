{
  "name": "@webpresso/docs-linter",
  "version": "0.1.0",
  "private": false,
  "description": "Documentation validation, linting, and enforcement for Webpresso",
  "bin": {
    "docs-check-internal-links": "./dist/cli/check-internal-links.js",
    "docs-check-refs": "./dist/cli/check-refs.js",
    "docs-check-stale": "./dist/cli/check-stale.js",
    "docs-lint": "./dist/cli/validate.js",
    "docs-migrate": "./dist/cli/migrate.js"
  },
  "type": "module",
  "imports": {
    "#schemas": "./dist/schemas/index.js",
    "#path-contract": "./dist/path-contract.js",
    "#*": "./dist/*.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "default": "./dist/generator/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "qa": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@manypkg/find-root": "^3.1.0",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "gray-matter": "^4.0.3",
    "markdownlint": "0.40.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tinyglobby": "^0.2.12",
    "unified": "^11.0.5",
    "yaml": "^2.8.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "@webpresso/typescript-config": "workspace:*",
    "@webpresso/vitest-config": "workspace:*",
    "markdownlint-cli2": "^0.22.0",
    "typescript": "^5.8.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
