{
  "name": "@webpresso/agent-docs-lint",
  "version": "0.2.1",
  "deprecated": "Deprecated: migrate to the consolidated webpresso package subpath exports. See https://github.com/webpresso/agent-kit/blob/main/MIGRATION.md",
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "description": "Documentation validation, linting, and enforcement for Webpresso",
  "bin": {
    "docs-check-internal-links": "./dist/cli/check-internal-links.js",
    "docs-check-refs": "./dist/cli/check-refs.js",
    "docs-check-stale": "./dist/cli/check-stale.js",
    "docs-lint": "./dist/cli/validate.js",
    "docs-migrate": "./dist/cli/migrate.js"
  },
  "type": "module",
  "imports": {
    "#schemas": "./dist/schemas/index.js",
    "#path-contract": "./dist/path-contract.js",
    "#*": "./dist/*.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "default": "./dist/generator/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "qa": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@manypkg/find-root": "catalog:",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "gray-matter": "catalog:",
    "markdownlint": "0.40.0",
    "remark-frontmatter": "catalog:",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tinyglobby": "^0.2.12",
    "unified": "^11.0.5",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@webpresso/agent-tsconfig": "workspace:*",
    "@webpresso/agent-vitest": "workspace:*",
    "markdownlint-cli2": "^0.22.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webpresso/tooling.git",
    "directory": "packages/docs-linter"
  }
}
