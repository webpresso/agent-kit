{
  "referenceConsumerBaselines": {
    "@webpresso/db-branching": "0.2.4",
    "@webpresso/db-branching-neon": "0.2.4"
  },
  "tarball": {
    "forbiddenPathPatterns": [
      "/^dist\\/.*\\.map$/",
      "/^dist\\/.*__integration__\\//",
      "/^dist\\/.*__mocks__\\//",
      "/^dist\\/.*runners\\/evals\\//",
      "/^dist\\/esm\\/ai-prompts\\//"
    ],
    "forbiddenContentPatterns": [
      "/ozby\\/ingest-lens/",
      "/webpresso\\/monorepo/"
    ]
  },
  "cliBins": {
    "public": [
      "wp",
      "docs-check-internal-links",
      "docs-check-refs",
      "docs-check-stale",
      "docs-lint",
      "docs-migrate",
      "with-secrets"
    ],
    "internalHooks": [
      "wp-precompact-snapshot"
    ]
  }
}
