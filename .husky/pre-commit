#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
if git diff --cached --name-only --diff-filter=ACMR | grep -Eq '^blueprints/(README\.md|[^/]+/.*\.md)$'; then
  "$ROOT/bin/wp" audit blueprint-readme-drift
fi
"$ROOT/bin/wp" audit guardrails
# agent-kit audit hooks (staged mode — fast)
# webpresso audit hooks (staged mode — fast)
"$ROOT/bin/wp" audit no-dev-vars
"$ROOT/bin/wp" audit absolute-path-policy --root "$ROOT"
"$ROOT/bin/wp" audit secret-provider-quarantine
