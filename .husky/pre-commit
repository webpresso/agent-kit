#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^blueprints/'; then
  "$ROOT/bin/wp" audit blueprint-readme-drift
fi
"$ROOT/bin/wp" audit guardrails
# agent-kit audit hooks (staged mode — fast)
# webpresso audit hooks (staged mode — fast)
bun "$ROOT/scripts/check-no-dev-vars.ts"
"$ROOT/bin/wp" audit absolute-path-policy --root "$ROOT"
bun "$ROOT/scripts/audit-secret-provider-quarantine.ts"
