#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"

"$ROOT/bin/wp" format --affected || exit 1

# Re-stage formatter rewrites for files that were already staged.
STAGED_AFTER_FORMAT="$(git diff --cached --name-only --diff-filter=ACMR)"
if [ -n "$STAGED_AFTER_FORMAT" ]; then
  printf '%s\n' "$STAGED_AFTER_FORMAT" | while IFS= read -r file; do
    [ -n "$file" ] || continue
    git add -- "$file" || exit 1
  done
fi

"$ROOT/bin/wp" audit guardrails --affected

# NOTE: the full whole-repo guardrails suite (catalog-drift, package-surface,
# reference-parity, and other repo-wide audits) is intentionally NOT run
# per-commit. It is a CI-grade gate owned by
# .github/workflows/ci.agent-kit.yml (and ci.yml) and runs on every PR.
